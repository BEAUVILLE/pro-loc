  <script>
    (() => {
      "use strict";

      const $ = (id) => document.getElementById(id);
      const SAVED_KEY = "digiy_loc_slug";

      function normPhone(p){
        if(!p) return "";
        let s = String(p).trim().replace(/\s+/g,"").replace(/[^\d+]/g,"");
        if (s.startsWith("00221")) s = "+221" + s.slice(5);
        if (!s.startsWith("+") && s.startsWith("221")) s = "+" + s;
        if (!s.startsWith("+221") && /^\d{9}$/.test(s)) s = "+221" + s;
        return s;
      }

      function isSensitiveSlug(slug){
        return /\d{7,}/.test(String(slug || ""));
      }

      function displayLieu(slug){
        const s = String(slug || "").trim();
        if(!s) return "—";

        if(isSensitiveSlug(s)){
          return "Espace logement sécurisé";
        }

        if(s.startsWith("loc-room-")){
          return "Logement " + s.slice(-6).toUpperCase();
        }

        return "Espace LOC";
      }

      function getUrlSlug(){
        try{
          return (new URL(location.href)).searchParams.get("slug") || "";
        }catch{
          return "";
        }
      }

      function getSavedSlug(){
        try{
          return localStorage.getItem(SAVED_KEY) || "";
        }catch{
          return "";
        }
      }

      function getSlug(){
        return (getUrlSlug() || getSavedSlug() || "").trim();
      }

      function saveSlug(slug){
        if(!slug) return;
        try{ localStorage.setItem(SAVED_KEY, slug); }catch(_){}
        try{ localStorage.setItem("digiy_last_slug", slug); }catch(_){}
      }

      function getHubPhone(){
        try{
          const u = new URL(location.href);
          const phone = normPhone(u.searchParams.get("phone") || "");

          if(phone){
            try{ sessionStorage.setItem("DIGIY_LOC_HUB_PHONE", phone); }catch(_){}
            window.DIGIY_LOC_HUB_PHONE = phone;
            return phone;
          }

          const saved = normPhone(
            (window.DIGIY_LOC_HUB_PHONE || "") ||
            (sessionStorage.getItem("DIGIY_LOC_HUB_PHONE") || "")
          );

          if(saved) window.DIGIY_LOC_HUB_PHONE = saved;
          return saved;
        }catch{
          try{
            const saved = normPhone(
              (window.DIGIY_LOC_HUB_PHONE || "") ||
              (sessionStorage.getItem("DIGIY_LOC_HUB_PHONE") || "")
            );
            if(saved) window.DIGIY_LOC_HUB_PHONE = saved;
            return saved;
          }catch{
            return window.DIGIY_LOC_HUB_PHONE || "";
          }
        }
      }

      function cleanVisibleUrl(slug){
        try{
          const u = new URL(location.href);
          let changed = false;

          if(u.searchParams.has("phone")){
            u.searchParams.delete("phone");
            changed = true;
          }

          if(isSensitiveSlug(slug) && u.searchParams.has("slug")){
            u.searchParams.delete("slug");
            changed = true;
          }

          if(changed){
            history.replaceState({}, "", u.pathname + u.search + u.hash);
          }
        }catch(_){}
      }

      function ensureSlugInUrl(slug){
        if(!slug) return;

        try{
          const u = new URL(location.href);
          let changed = false;

          if(u.searchParams.has("phone")){
            u.searchParams.delete("phone");
            changed = true;
          }

          if(isSensitiveSlug(slug)){
            if(u.searchParams.has("slug")){
              u.searchParams.delete("slug");
              changed = true;
            }
          } else if(!u.searchParams.get("slug")){
            u.searchParams.set("slug", slug);
            changed = true;
          }

          if(changed){
            history.replaceState({}, "", u.pathname + u.search + u.hash);
          }
        }catch(_){}
      }

      function clearLocalLocSession(){
        try{
          localStorage.removeItem("digiy_loc_slug");
          localStorage.removeItem("digiy_last_slug");
          sessionStorage.removeItem("DIGIY_LOC_HUB_PHONE");
        }catch(_){}
      }

      function getGuardState(){
        return window.DIGIY_GUARD?.state || {
          preview: true,
          access_ok: false,
          slug: "",
          phone: "",
          reason: "guard_missing"
        };
      }

      async function waitGuardReady(){
        if(!window.DIGIY_GUARD || typeof window.DIGIY_GUARD.ready !== "function"){
          throw new Error("guard_absent");
        }
        return await window.DIGIY_GUARD.ready({ redirect:false, timeout:8000 });
      }

      function getSb(){
        return window.DIGIY_GUARD?.getSb?.() || window.sb || null;
      }

      function withSlug(target){
        const slug = getGuardState().slug || getSlug();

        if(target === "__back__") return target;

        try{
          const u = new URL(target, location.href);

          if(slug && !isSensitiveSlug(slug) && !u.searchParams.get("slug")){
            u.searchParams.set("slug", slug);
          }

          u.searchParams.delete("phone");

          if(u.origin === location.origin) return u.pathname + u.search + u.hash;
          return u.toString();
        }catch{
          let out = target;
          if(slug && !isSensitiveSlug(slug)){
            out += (out.includes("?") ? "&" : "?") + "slug=" + encodeURIComponent(slug);
          }
          return out;
        }
      }

      function show(msg, cls){
        const el = $("note");
        if(!el) return;
        el.className = "note " + (cls || "warn");
        el.textContent = msg || "";
        el.style.display = msg ? "block" : "none";
      }

      function disablePrivateDoors(){
        const allowed = new Set([
          "__back__",
          "pin.html",
          "go-pin-public.html"
        ]);

        document.querySelectorAll("[data-go]").forEach((el) => {
          const target = (el.getAttribute("data-go") || "").trim();
          if(!allowed.has(target)){
            el.setAttribute("aria-disabled", "true");
            el.setAttribute("tabindex", "-1");
          }
        });

        const check = $("btnCheckAccess");
        if(check){
          check.setAttribute("aria-disabled", "true");
          check.setAttribute("tabindex", "-1");
        }
      }

      function enablePrivateDoors(){
        document.querySelectorAll("[data-go]").forEach((el) => {
          el.removeAttribute("aria-disabled");
          el.removeAttribute("tabindex");
        });

        const check = $("btnCheckAccess");
        if(check){
          check.removeAttribute("aria-disabled");
          check.removeAttribute("tabindex");
        }
      }

      function setPills({ phone, slug, ok, preview }){
        const lieuLabel = displayLieu(slug);

        $("pillLieu").textContent = "Lieu : " + lieuLabel;
        $("vLieu").textContent = lieuLabel;

        $("pillPhone").textContent = "👤 Compte sécurisé";
        $("vPhone").textContent = phone ? "Compte reconnu" : "Compte sécurisé";

        if(ok){
          $("pillConn").className = "pill ok";
          $("pillConn").textContent = "✅ Connecté";
        } else if (preview) {
          $("pillConn").className = "pill";
          $("pillConn").textContent = "👁️ Aperçu";
        } else {
          $("pillConn").className = "pill bad";
          $("pillConn").textContent = "Bloqué ❌";
        }
      }

      function sbState(){
        const sb = getSb();
        const ok = !!(sb && typeof sb.from === "function" && typeof sb.rpc === "function");
        $("vSb").textContent = ok ? "OK" : "Pas prêt";
        return ok;
      }

      function bindNav(){
        document.querySelectorAll("[data-go]").forEach((el)=>{
          if(el.__digiy_bound) return;
          el.__digiy_bound = true;

          const targetRaw = (el.getAttribute("data-go") || "").trim();
          const mode = (el.getAttribute("data-mode") || "assign").trim();

          el.addEventListener("click", (e)=>{
            e.preventDefault();

            if(el.getAttribute("aria-disabled") === "true"){
              show("🔒 Accès privé non confirmé.\n➡️ Ouvre d’abord ton accès avec ton code.", "warn");
              return;
            }

            if(!targetRaw) return;

            if(targetRaw === "__back__"){
              if(history.length > 1) return history.back();
              const t = withSlug("pin.html");
              if(window.DIGIY_GUARD?.go) return window.DIGIY_GUARD.go(t, "replace");
              return location.replace(t);
            }

            const target = withSlug(targetRaw);

            if(window.DIGIY_GUARD?.go) return window.DIGIY_GUARD.go(target, mode);
            if(mode === "replace") location.replace(target);
            else location.assign(target);
          });
        });
      }

      function setPreviewUi(reason){
        const st = getGuardState();
        const slug = st.slug || getSlug();
        const phone = st.phone || getHubPhone() || "";

        disablePrivateDoors();

        setPills({
          phone,
          slug,
          ok: false,
          preview: true
        });

        $("vSess").textContent = "Aperçu";
        $("btnLogout").style.display = "none";

        show(
          reason === "slug_missing"
            ? "👁️ Aucun lieu détecté.\n➡️ Ouvre cette page depuis ton lien d’entrée ou repasse par ton accès."
            : reason === "has_access_false"
            ? "👁️ Lieu reconnu mais accès non actif.\n➡️ Passe par ton code pour ouvrir les portes privées."
            : "👁️ Mode aperçu.\n➡️ Les portes privées restent fermées tant que l’accès n’est pas confirmé.",
          "warn"
        );
      }

      function setLiveUi(){
        const st = getGuardState();
        const phone = (st.phone || getHubPhone() || "").trim();
        const slug = (st.slug || getSlug() || "").trim();

        enablePrivateDoors();

        setPills({
          phone,
          slug,
          ok: !!st.access_ok,
          preview: false
        });

        $("vSess").textContent = st.access_ok ? "OK" : "—";
        $("btnLogout").style.display = "inline-flex";

        if(sbState()){
          show("", "warn");
        } else {
          show("⚠️ Connexion pas encore prête.\n➡️ Clique ↻ Recharger ou repasse par ton code.", "warn");
        }
      }

      $("btnReload")?.addEventListener("click", ()=> location.reload());

      $("btnLogout")?.addEventListener("click", async ()=>{
        if(!confirm("Se déconnecter ?")) return;

        const pinTarget = withSlug("pin.html");
        clearLocalLocSession();

        try{
          if(window.DIGIY_GUARD?.logout){
            await window.DIGIY_GUARD.logout(pinTarget);
            return;
          }
        }catch(err){
          console.error("[LOC] logout error", err);
        }

        location.replace(pinTarget);
      });

      $("btnCheckAccess")?.addEventListener("click", async (e)=>{
        e.preventDefault();

        if(e.currentTarget.getAttribute("aria-disabled") === "true"){
          show("🔒 Contrôle réservé à une session ouverte.\n➡️ Passe d’abord par ton accès.", "warn");
          return;
        }

        try{
          await waitGuardReady();

          const st = getGuardState();
          const sb = getSb();
          const slug = (st.slug || getSlug() || "").trim();
          const phone = (st.phone || getHubPhone() || "").trim();

          if(!st.access_ok) throw new Error("access_not_confirmed");
          if(!slug) throw new Error("slug_missing");
          if(!phone) throw new Error("phone_missing");
          if(!sb || typeof sb.rpc !== "function") throw new Error("sb_missing");

          const { data, error } = await sb.rpc("digiy_has_access", {
            p_phone: phone,
            p_module: "LOC"
          });

          if(error) throw error;

          alert(
            "✅ ACCÈS\n" +
            "lieu = " + displayLieu(slug) + "\n" +
            "compte = reconnu\n" +
            "ouvert = " + (data ? "oui" : "non")
          );
        }catch(err){
          alert("❌ KO\n" + (err?.message || String(err)));
        }
      });

      async function init(){
        bindNav();

        const mo = new MutationObserver(() => bindNav());
        mo.observe(document.querySelector(".wrap") || document.body, {
          childList: true,
          subtree: true
        });

        const hubPhone = getHubPhone();
        const rawUrlSlug = getUrlSlug();

        if(rawUrlSlug){
          saveSlug(rawUrlSlug);
        }

        const initialSlug = (rawUrlSlug || getSavedSlug() || "").trim();

        cleanVisibleUrl(initialSlug);

        if(initialSlug){
          ensureSlugInUrl(initialSlug);
        }

        if(!initialSlug){
          setPreviewUi("slug_missing");
          setPills({ phone: hubPhone, slug: "", ok: false, preview: true });
          $("vSess").textContent = "—";
          $("btnLogout").style.display = "none";
          sbState();
          return;
        }

        if(!window.DIGIY_GUARD){
          throw new Error("guard_absent");
        }

        await waitGuardReady();

        const st = getGuardState();
        const finalSlug = (st.slug || initialSlug || "").trim();

        if(finalSlug){
          saveSlug(finalSlug);
          ensureSlugInUrl(finalSlug);
        }

        if(!st.access_ok){
          setPreviewUi(st.reason || "preview");
        } else {
          setLiveUi();
        }
      }

      init().catch((e)=>{
        console.error(e);
        const slug = getSlug();
        const phone = getHubPhone();
        disablePrivateDoors();
        cleanVisibleUrl(slug);
        show("🔴 Crash JS.\n" + (e?.message || e), "bad");
        setPills({ phone, slug, ok:false, preview:false });
        $("vSess").textContent = "KO";
        $("btnLogout").style.display = "none";
        sbState();
      });
    })();
  </script>

  <script>
    (function(){
      "use strict";

      const AUDIO_TEXT = "Bienvenue dans Je loue by DIGIY. Ici, toutes les portes sont posées pour gérer l’essentiel de ton logement : les réservations, les disponibilités, les notes rapides, la fiche publique et les paiements utiles. Tu peux ouvrir la vue du jour, regarder ton planning, bloquer tes dates, préparer ton QR, vérifier ton accès et revenir à ton espace sans te perdre. Le client voit plus clair, le propriétaire garde la main, et l’argent reste direct. DIGIY ne prend pas la commission : il t’aide à organiser ton lieu, simplement.";

      const btnPlay = document.getElementById("btnLocAudio");
      const btnStop = document.getElementById("btnLocAudioStop");
      const bar = document.getElementById("locAudioProgress");
      let playing = false;
      let timer = null;

      function pickVoice(){
        try{
          const voices = window.speechSynthesis.getVoices() || [];
          return voices.find(v => /^fr/i.test(v.lang || "") && /audrey|amelie|hortense|julie|thomas|paul|french/i.test(v.name || ""))
              || voices.find(v => /^fr/i.test(v.lang || ""))
              || null;
        }catch(_){ return null; }
      }

      function stopAudio(){
        try{ window.speechSynthesis.cancel(); }catch(_){ }
        clearInterval(timer);
        timer = null;
        playing = false;
        if(btnPlay) btnPlay.textContent = "🎧 Écouter DIGIY";
        if(bar) bar.style.width = "0%";
      }

      function playAudio(){
        if(!("speechSynthesis" in window) || !("SpeechSynthesisUtterance" in window)){
          alert("Audio indisponible sur ce navigateur.");
          return;
        }
        if(playing){ stopAudio(); return; }

        stopAudio();
        const utter = new SpeechSynthesisUtterance(AUDIO_TEXT);
        utter.lang = "fr-FR";
        utter.rate = 0.86;
        utter.pitch = 1.03;
        utter.volume = 1;
        const voice = pickVoice();
        if(voice) utter.voice = voice;

        let progress = 0;
        const duration = Math.max(12000, AUDIO_TEXT.split(/\s+/).length * 410);

        utter.onstart = function(){
          playing = true;
          if(btnPlay) btnPlay.textContent = "⏸️ Lecture en cours";
          if(bar) bar.style.width = "0%";
          timer = setInterval(function(){
            progress += 250;
            if(bar) bar.style.width = Math.min(96, (progress / duration) * 100) + "%";
          }, 250);
        };

        utter.onend = function(){
          if(bar) bar.style.width = "100%";
          setTimeout(stopAudio, 250);
        };
        utter.onerror = stopAudio;

        window.speechSynthesis.speak(utter);
      }

      if(btnPlay) btnPlay.addEventListener("click", playAudio);
      if(btnStop) btnStop.addEventListener("click", stopAudio);
      if(window.speechSynthesis && typeof window.speechSynthesis.onvoiceschanged !== "undefined"){
        window.speechSynthesis.onvoiceschanged = pickVoice;
      }
      window.addEventListener("beforeunload", stopAudio);
      document.addEventListener("visibilitychange", function(){ if(document.hidden) stopAudio(); });
    })();
  </script>

<script>
(function(){
  function scrub(){
    document.querySelectorAll('body *').forEach(function(el){
      if(!el || el.children.length) return;
      var t=el.textContent||'';
      var n=t.replace(/loc-\d{7,}/gi,'Espace logement sécurisé').replace(/(?:\+?221)?\d{9,}/g,function(m){return /[0-9]/.test(m)?'Compte reconnu':m});
      if(n!==t) el.textContent=n;
    });
    document.querySelectorAll('a[href]').forEach(function(a){try{var u=new URL(a.getAttribute('href'),location.href);u.searchParams.delete('phone');var s=u.searchParams.get('slug')||'';if(/\d{7,}/.test(s))u.searchParams.delete('slug');a.setAttribute('href',u.origin===location.origin?u.pathname+u.search+u.hash:u.toString());}catch(e){}});
  }
  scrub(); new MutationObserver(scrub).observe(document.body,{childList:true,subtree:true,characterData:true});
})();
</script>
